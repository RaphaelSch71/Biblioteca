# Copie este arquivo para .env e ajuste os valores para o seu ambiente

# SQL Server
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_SERVER=localhost\SQLEXPRESS
DB_NAME=BibliotecaBD

# True = autenticação integrada do Windows
DB_TRUSTED=true

# Se DB_TRUSTED=false, preencha:
DB_UID=
DB_PWD=

# Opções extras de conexão
DB_TIMEOUT=5
DB_ENCRYPT=no
DB_TRUST_SERVER_CERTIFICATE=yes

# Se true, a aplicação NÃO cai para memória quando o SQL falhar
STRICT_SQL=false

# Bootstrap admin (apenas quando o banco está vazio)
ADMIN_NOME=Administrador
ADMIN_MATRICULA=ADM001
ADMIN_SENHA=admin

# Código mestre para geração de código de bibliotecário
BIBLIOTECARIO_CODIGO_MASTER=BIB-2026
